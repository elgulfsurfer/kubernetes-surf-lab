# ── Terraform ─────────────────────────────────────────────────────────────────
# State files — managed remotely in S3, never commit locally
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable files — may contain account IDs, ARNs, secrets
*.tfvars
!*.tfvars.example

# Terraform working directory and plan output
.terraform/
*.tfplan

# Crash logs
crash.log
crash.*.log

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Docker ────────────────────────────────────────────────────────────────────
# Local override files (may have real credentials)
docker-compose.override.yml

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Rendered secret manifests — use sealed-secrets or external-secrets in prod
surfapp/k8s/secret.yaml

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Excluded project folders ──────────────────────────────────────────────────
resume-app/
app/
terraform/

# ── Personal ──────────────────────────────────────────────────────────────────
chat.txt
