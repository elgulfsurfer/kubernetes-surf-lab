# Terraform state — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Local variable overrides — may contain secrets
*.tfvars
!*.tfvars.example

# Terraform working directory
.terraform/

# Crash logs
crash.log
crash.*.log

# Provider binaries downloaded by terraform init
*.tfplan

# macOS
.DS_Store

# Personal notes
chat.txt
